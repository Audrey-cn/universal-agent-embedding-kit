      "code": "def calculator(expr):\n    expr = expr.replace(\" \", \"\")\n    nums, ops = [], []\n    num = 0\n    for ch in expr:\n        if ch.isdigit():\n            num = num * 10 + int(ch)\n        else:\n            nums.append(num)\n            ops.append(ch)\n            num = 0\n    nums.append(num)\n\n    # First pass: handle multiplication\n    new_nums = [nums[0]]\n    new_ops = []\n    for i in range(len(ops)):\n        if ops[i] == \"*\":\n            new_nums[-1] *= nums[i + 1]\n        else:\n            new_nums.append(nums[i + 1])\n            new_ops.append(ops[i])\n\n    # Second pass: handle addition and subtraction left-to-right\n    result = new_nums[0]\n    for i in range(len(new_ops)):\n        if new_ops[i] == \"+\":\n            result += new_nums[i + 1]\n        else:\n            result -= new_nums[i + 1]\n\n    return result",
