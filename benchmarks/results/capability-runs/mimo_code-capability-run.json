      "code": "def longest_unique_substring(s):\n    char_index = {}\n    max_length = 0\n    start = 0\n    for end, char in enumerate(s):\n        if char in char_index and char_index[char] >= start:\n            start = char_index[char] + 1\n        char_index[char] = end\n        max_length = max(max_length, end - start + 1)\n    return max_length",
