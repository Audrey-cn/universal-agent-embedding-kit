      "code": "def lru_cache_sim(capacity, ops):\n    cache = {}\n    order = []\n    results = []\n    for op in ops:\n        if op[0] == 'put':\n            k, v = op[1], op[2]\n            if k in cache:\n                order.remove(k)\n            cache[k] = v\n            order.append(k)\n            if len(cache) > capacity:\n                evict = order.pop(0)\n                del cache[evict]\n        elif op[0] == 'get':\n            k = op[1]\n            if k in cache:\n                order.remove(k)\n                order.append(k)\n                results.append(cache[k])\n            else:\n                results.append(-1)\n    return results",
