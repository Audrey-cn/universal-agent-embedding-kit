      "code": "def calculator(expr):\n    tokens = []\n    i = 0\n    s = expr.replace(\" \", \"\")\n    while i < len(s):\n        if s[i].isdigit():\n            j = i\n            while j < len(s) and s[j].isdigit():\n                j += 1\n            tokens.append(int(s[i:j]))\n            i = j\n        else:\n            tokens.append(s[i])\n            i += 1\n\n    # first pass: resolve *\n    resolved = [tokens[0]]\n    i = 1\n    while i < len(tokens):\n        op = tokens[i]\n        rhs = tokens[i + 1]\n        if op == '*':\n            resolved[-1] = resolved[-1] * rhs\n        else:\n            resolved.append(op)\n            resolved.append(rhs)\n        i += 2\n\n    # second pass: resolve + and -\n    result = resolved[0]\n    i = 1\n    while i < len(resolved):\n        op = resolved[i]\n        rhs = resolved[i + 1]\n        if op == '+':\n            result += rhs\n        else:\n            result -= rhs\n        i += 2\n\n    return result",
