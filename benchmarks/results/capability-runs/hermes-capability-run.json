      "code": "def longest_unique_substring(s: str) -> int:\n    seen = {}\n    start = 0\n    max_len = 0\n    for i, ch in enumerate(s):\n        if ch in seen and seen[ch] >= start:\n            start = seen[ch] + 1\n        seen[ch] = i\n        max_len = max(max_len, i - start + 1)\n    return max_len",
