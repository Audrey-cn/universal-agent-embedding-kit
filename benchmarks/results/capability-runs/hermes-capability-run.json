      "code": "def lru_cache_sim(capacity, ops):\n    from collections import OrderedDict\n    cache = OrderedDict()\n    result = []\n    for op in ops:\n        if op[0] == 'put':\n            key, value = op[1], op[2]\n            if key in cache:\n                cache.move_to_end(key)\n            cache[key] = value\n            if len(cache) > capacity:\n                cache.popitem(last=False)\n        elif op[0] == 'get':\n            key = op[1]\n            if key in cache:\n                cache.move_to_end(key)\n                result.append(cache[key])\n            else:\n                result.append(-1)\n    return result",
