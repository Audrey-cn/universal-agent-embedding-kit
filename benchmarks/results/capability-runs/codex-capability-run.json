      "code": "def calculator(expr):\n    total = 0\n    last = 0\n    num = 0\n    op = \"+\"\n\n    for ch in expr + \"+\":\n        if ch == \" \":\n            continue\n        if ch.isdigit():\n            num = num * 10 + int(ch)\n            continue\n\n        if op == \"+\":\n            total += last\n            last = num\n        elif op == \"-\":\n            total += last\n            last = -num\n        elif op == \"*\":\n            last *= num\n\n        op = ch\n        num = 0\n\n    return total + last",
