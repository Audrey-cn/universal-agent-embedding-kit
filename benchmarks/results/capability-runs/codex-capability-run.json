      "code": "def roman_to_int(s):\n    values = {\n        \"I\": 1,\n        \"V\": 5,\n        \"X\": 10,\n        \"L\": 50,\n        \"C\": 100,\n        \"D\": 500,\n        \"M\": 1000,\n    }\n    total = 0\n    prev = 0\n\n    for ch in reversed(s):\n        value = values[ch]\n        if value < prev:\n            total -= value\n        else:\n            total += value\n            prev = value\n\n    return total",
