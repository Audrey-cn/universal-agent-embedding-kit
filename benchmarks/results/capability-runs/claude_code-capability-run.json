      "code": "def roman_to_int(s):\n    values = {'I': 1, 'V': 5, 'X': 10, 'L': 50, 'C': 100, 'D': 500, 'M': 1000}\n    result = 0\n    for i, c in enumerate(s):\n        if i + 1 < len(s) and values[c] < values[s[i + 1]]:\n            result -= values[c]\n        else:\n            result += values[c]\n    return result",
