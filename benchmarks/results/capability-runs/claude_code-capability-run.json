      "code": "def calculator(expr):\n    tokens = []\n    i = 0\n    s = expr.replace(' ', '')\n    while i < len(s):\n        if s[i].isdigit():\n            j = i\n            while j < len(s) and s[j].isdigit():\n                j += 1\n            tokens.append(int(s[i:j]))\n            i = j\n        else:\n            tokens.append(s[i])\n            i += 1\n    # first pass: evaluate *\n    new = [tokens[0]]\n    i = 1\n    while i < len(tokens):\n        op = tokens[i]\n        if op == '*':\n            new[-1] = new[-1] * tokens[i + 1]\n            i += 2\n        else:\n            new.append(op)\n            new.append(tokens[i + 1])\n            i += 2\n    # second pass: evaluate + and -\n    result = new[0]\n    i = 1\n    while i < len(tokens := new):\n        op = tokens[i]\n        if op == '+':\n            result += tokens[i + 1]\n        else:\n            result -= tokens[i + 1]\n        i += 2\n    return result",
